{
  "name": "flashcards",
  "main": "index",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:e2e": "expo start --clear",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "expo run:android --variant release",
    "build:ios": "expo run:ios --configuration Release",
    "build:web": "expo export --platform web",
    "deploy:web:dev": "npx expo export --platform web && eas deploy",
    "deploy:web:prod": "npx expo export --platform web && eas deploy --prod",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "e2e": "maestro test --no-ansi .maestro/main.yaml",
    "e2e:android": "maestro --platform android test --no-ansi .maestro/main.yaml",
    "e2e:ios": "maestro --platform ios test --no-ansi .maestro/main.yaml"
  },
  "dependencies": {
    "@domenico-esposito/react-native-markdown-editor": "^0.2.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/react-native-skia": "2.2.12",
    "@tamagui/accordion": "^1.144.3",
    "@tamagui/button": "^1.144.3",
    "@tamagui/card": "^1.144.3",
    "@tamagui/config": "^1.144.3",
    "@tamagui/core": "^1.144.3",
    "@tamagui/font-inter": "^1.144.3",
    "@tamagui/popover": "^2.0.0-rc.0",
    "@tamagui/portal": "^1.144.3",
    "@tamagui/shorthands": "^1.144.3",
    "expo": "~54.0.32",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "^55.0.8",
    "expo-router": "~6.0.22",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.13",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tamagui": "^1.144.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "packageManager": "npm@10.9.2",
  "private": true
}
